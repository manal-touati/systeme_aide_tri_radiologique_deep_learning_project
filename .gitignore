"""
Template : .gitignore
"""
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Data
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Models
models/*.pt
models/*.pth
models/*.ggml
!models/.gitkeep

# MLflow
mlruns/
.mlflow/

# Plots
plots/*.png
plots/*.jpg
plots/*.pdf
!plots/.gitkeep

# Logs
*.log
logs/

# Cache
.cache/
*.cache

# Credentials & Secrets
kaggle.json
.env
*.pem
*.key
